{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chess-analysis": {
      "type": "remote",
      "url": "http://localhost:8000/sse"
    },
    "chess-files": {
      "type": "local",
      "command": ["uv", "run", "--directory", "server", "chess-files"],
      "environment": { "CHESS_MCP_URL": "http://localhost:8000/sse" }
    }
  }
}
